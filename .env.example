# GitPal production environment
# Copy this file to your runtime secret manager or `.env` for local Docker runs.
# Do not commit real secrets. Empty optional values are treated as unset.

# ---------------------------------------------------------------------------
# App URLs
# ---------------------------------------------------------------------------
# Public web application origin. Used by auth redirects, CORS, and billing links.
CORS_ORIGIN=https://app.example.com

# Public API/server origin. The web app calls `${NEXT_PUBLIC_SERVER_URL}/trpc`.
NEXT_PUBLIC_SERVER_URL=https://api.example.com

# Better Auth base URL. Usually the same as NEXT_PUBLIC_SERVER_URL.
BETTER_AUTH_URL=https://api.example.com

# Optional shared cookie domain for sibling subdomains.
# Leave unset for localhost or single-origin deployments.
BETTER_AUTH_COOKIE_DOMAIN=

# ---------------------------------------------------------------------------
# Core secrets and persistence
# ---------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-at-least-32-characters

# Primary application database.
DATABASE_URL=postgres://postgres:replace-me@postgres:5432/gitpal
POSTGRES_PASSWORD=replace-me

# Primary application Redis. Docker Compose injects redis://redis:6379.
REDIS_URL=redis://redis:6379

# Chat SDK state, dedupe, and distributed locks use Redis. Point this at a
# separate logical DB or Redis service when queue traffic shares REDIS_URL.
GITPAL_CHAT_REDIS_URL=redis://redis:6379/1
GITPAL_CHAT_STATE_KEY_PREFIX=gitpal:chat

# ---------------------------------------------------------------------------
# Server runtime
# ---------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
TRUST_PROXY_HEADERS=false
HTTP_MAX_REQUEST_BODY_BYTES=5242880

# Database pool tuning.
GITPAL_DB_POOL_MAX=10
GITPAL_DB_POOL_IDLE_TIMEOUT_MS=30000
GITPAL_DB_POOL_CONNECTION_TIMEOUT_MS=10000

# Cloud-only wallet billing. Keep false for self-hosted deployments.
GITPAL_CLOUD_BILLING_ENABLED=false
NEXT_PUBLIC_GITPAL_CLOUD_BILLING_ENABLED=false

# ---------------------------------------------------------------------------
# AI providers
# ---------------------------------------------------------------------------
# Recommended for hosted deployments using Vercel AI Gateway.
AI_GATEWAY_API_KEY=

# Optional direct provider routes.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/api

# Default review model. Users can override with BYOK routing.
GITPAL_AI_MODEL=anthropic/claude-sonnet-4.6

# ---------------------------------------------------------------------------
# Git providers and webhooks
# ---------------------------------------------------------------------------
# OAuth apps enable GitHub/GitLab login and cloud repository sync.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# GitHub App credentials enable app-installation repository access.
GITHUB_APP_ID=
# Paste PEM with literal \n characters if your host cannot store multiline envs.
GITHUB_APP_PRIVATE_KEY=

# Webhook secrets should match provider configuration.
GITHUB_WEBHOOK_SECRET=
GITLAB_WEBHOOK_SECRET=
GITLAB_WEBHOOK_SIGNING_SECRET=

# Optional override for webhook URLs when the API is behind a public tunnel/proxy.
GITPAL_WEBHOOK_BASE_URL=

# ---------------------------------------------------------------------------
# MCP and product integrations
# ---------------------------------------------------------------------------
# OAuth for Notion and Linear connector flows.
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
LINEAR_OAUTH_CLIENT_ID=
LINEAR_OAUTH_CLIENT_SECRET=

# Notification channel credentials are usually user-configured in the app.
# These optional Chat SDK vars support shared/webhook-capable notification bots.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_BOT_USERNAME=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_ENCRYPTION_KEY=
SLACK_BOT_USERNAME=
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
TEAMS_APP_TENANT_ID=
TEAMS_BOT_USERNAME=
LINEAR_API_KEY=
LINEAR_ACCESS_TOKEN=
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_WEBHOOK_SECRET=
LINEAR_BOT_USERNAME=
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
RESEND_FROM_ADDRESS=
RESEND_FROM_NAME=

# ---------------------------------------------------------------------------
# Billing
# ---------------------------------------------------------------------------
NOWPAYMENTS_API_BASE_URL=https://api.nowpayments.io
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
GITPAL_WALLET_REVENUE_SHARE_PERCENT=5

# ---------------------------------------------------------------------------
# Queue and workflow controls
# ---------------------------------------------------------------------------
GITPAL_QUEUE_PREFIX=gitpal
GITPAL_QUEUE_PRODUCER_MAX_RETRIES_PER_REQUEST=3
GITPAL_QUEUE_JOB_ATTEMPTS=5
GITPAL_QUEUE_JOB_BACKOFF_MS=1000
GITPAL_QUEUE_REMOVE_ON_COMPLETE=1000
GITPAL_QUEUE_REMOVE_ON_FAIL=5000

GITPAL_PROVIDER_WEBHOOK_WORKER_CONCURRENCY=5
GITPAL_PROVIDER_WEBHOOK_QUEUE_RATE_LIMIT_MAX=0
GITPAL_PROVIDER_WEBHOOK_QUEUE_RATE_LIMIT_DURATION_MS=1000

GITPAL_REPO_SYNC_ACCOUNT_CONCURRENCY=4
GITPAL_REPO_SYNC_USER_CONCURRENCY=1
GITPAL_REPO_SYNC_THROTTLE_LIMIT=20
GITPAL_REPO_SYNC_THROTTLE_PERIOD_SECONDS=60
GITPAL_REPO_SYNC_RATE_LIMIT=120
GITPAL_REPO_SYNC_RATE_LIMIT_PERIOD_SECONDS=3600

GITPAL_AI_WORKFLOW_ACCOUNT_CONCURRENCY=4
GITPAL_AI_WORKFLOW_REPOSITORY_CONCURRENCY=1
GITPAL_AI_WORKFLOW_THROTTLE_LIMIT=30
GITPAL_AI_WORKFLOW_THROTTLE_PERIOD_SECONDS=60

# ---------------------------------------------------------------------------
# Inngest self-hosting
# ---------------------------------------------------------------------------
INNGEST_BASE_URL=http://inngest:8288
# For the host-run dev workflow, override this to http://localhost:8288.
# Generate independent 32+ character values.
INNGEST_EVENT_KEY=replace-with-at-least-32-characters
INNGEST_SIGNING_KEY=replace-with-at-least-32-characters

INNGEST_POSTGRES_DB=inngest
INNGEST_POSTGRES_USER=inngest
INNGEST_POSTGRES_PASSWORD=replace-me
INNGEST_POSTGRES_URI=postgres://inngest:replace-me@postgres-inngest:5432/inngest
INNGEST_REDIS_URI=redis://redis-inngest:6379
INNGEST_POLL_INTERVAL=15
INNGEST_QUEUE_WORKERS=100
INNGEST_RETRY_INTERVAL=1
INNGEST_TICK=150
INNGEST_LOG_LEVEL=info
INNGEST_JSON=false
INNGEST_VERBOSE=false

# Optional Traefik exposure for the Inngest dashboard.
INNGEST_DASHBOARD_TRAEFIK_ENABLE=false
INNGEST_DASHBOARD_HOST=inngest.example.com
INNGEST_DASHBOARD_TRAEFIK_ENTRYPOINTS=websecure
INNGEST_DASHBOARD_TRAEFIK_TLS=true
INNGEST_DASHBOARD_BASIC_AUTH_USERS=

# ---------------------------------------------------------------------------
# Build and validation
# ---------------------------------------------------------------------------
NEXT_TELEMETRY_DISABLED=1
# Only use this for local diagnosis. Do not use it in production.
SKIP_ENV_VALIDATION=false
