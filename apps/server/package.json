{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run --hot src/index.ts",
		"start": "bun run dist/index.mjs"
	},
	"dependencies": {
		"@gitpal/api": "workspace:*",
		"@gitpal/auth": "workspace:*",
		"@gitpal/db": "workspace:*",
		"@gitpal/env": "workspace:*",
		"@gitpal/jobs": "workspace:*",
		"@gitpal/logger": "workspace:*",
		"@hono/trpc-server": "^0.4.0",
		"@trpc/server": "catalog:",
		"ai": "catalog:",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"hono": "^4.12.26",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@gitpal/config": "workspace:*",
		"@types/bun": "catalog:",
		"tsdown": "^0.21.9",
		"typescript": "catalog:"
	}
}