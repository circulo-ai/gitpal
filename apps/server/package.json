{
  "name": "server",
  "type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "workflow build && tsdown",
		"check-types": "workflow build && tsc -b",
		"compile": "workflow build && bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run src/dev.ts",
		"workflow:build": "workflow build",
		"start": "bun run dist/index.mjs"
	},
	"dependencies": {
		"@gitpal/api": "workspace:*",
		"@gitpal/auth": "workspace:*",
		"@gitpal/db": "workspace:*",
		"@gitpal/env": "workspace:*",
		"@workflow-worlds/redis": "catalog:",
		"@workflow/ai": "catalog:",
		"@hono/trpc-server": "^0.4.0",
		"@trpc/server": "catalog:",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"ai": "catalog:",
		"hono": "catalog:",
		"workflow": "catalog:",
		"zod": "catalog:"
	},
  "devDependencies": {
    "@gitpal/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.21.9",
    "typescript": "catalog:"
  }
}
