{
	"name": "worker",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile worker",
		"dev": "bun run src/index.ts",
		"start": "bun run dist/index.mjs"
	},
	"dependencies": {
		"@gitpal/api": "workspace:*",
		"@gitpal/env": "workspace:*",
		"@gitpal/jobs": "workspace:*",
		"@gitpal/logger": "workspace:*",
		"dotenv": "catalog:"
	},
	"devDependencies": {
		"@gitpal/config": "workspace:*",
		"@types/bun": "catalog:",
		"tsdown": "^0.21.9",
		"typescript": "catalog:"
	}
}
